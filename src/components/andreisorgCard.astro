---
const { billede, titel, tekst, direction } = Astro.props;
---

<article class={direction}>
  <div class="content">
    <h3>{titel}</h3>
    <p class="tekst">{tekst}</p>
  </div>
  <img src={billede} />
</article>

<style>
  p {
    padding: 1em 1em;
  }

  h3 {
    color: #32487a;
  }
  article {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  img {
    max-width: 50%;
    align-self: center;
  }

  @media screen and (width >= 800px) {
    img {
      max-width: 25%;
    }

    article {
      flex-direction: row;
      align-items: center;
    }
    article.left {
      flex-direction: row-reverse;
      margin: 0;
      padding: 0;
    }
  }
</style>
