---
const { titel, tekst, billede, direction } = Astro.props;
---

<article class={direction}>
  <div class="content">
    <h3>{titel}</h3>
    <p class="tekst">{tekst}</p>
  </div>
  <img src={billede} />
</article>

<style>
  h3 {
    color: #32487a;
  }

  p {
    padding: 1em 0;
    line-height: 1.5rem;
  }

  article {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 2rem auto;
    margin-bottom: 4rem;
  }

  img {
    max-width: 50%;
    align-self: center;
  }

  @media screen and (width >= 800px) {
    img {
      max-width: 25%;
    }

    article {
      flex-direction: row;
      align-items: center;
      max-width: 900px;
    }
    article.left {
      flex-direction: row-reverse;
    }
  }
</style>
