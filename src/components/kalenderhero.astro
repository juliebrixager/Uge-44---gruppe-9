---

---

<section class="hero">
  <img src="/imgs/kalender-hero-figur.png" alt="" />
  <span class="herotekst">
    <h1>Kalender</h1>
    <h2>Her finder du kommende events og arrangementer - både i og udenfor uge 44</h2>
  </span>
</section>

<style>
  .hero {
    position: relative;
    background: #bcceff;
    min-height: 90vh;
    overflow: hidden;
  }

  h1 {
    color: #1a4096;
    padding-bottom: 15px;
    font-size: 2rem;
  }
  h2 {
    color: white;
    font-size: 1.2rem;
  }

  .hero img {
    width: 120px;
    display: flex;
    justify-content: right;
    align-items: flex-end;
    padding: 0%;
  }

  .hero img {
    position: absolute;
    top: 120px; /* justér efter behov */
    right: 80px; /* skubber den ind fra højre */
    width: 180px; /* lidt større som i design */
  }

  .herotekst {
    position: absolute;
    top: 50%;
    left: 50px; /* i stedet for 50% */
    transform: translateY(-50%);
    max-width: 400px;
  }

  @media (min-width: 768px) {
    .hero img {
      width: 120px;
      display: flex;
      justify-content: right;
      align-items: flex-end;
      padding: 0%;
    }

    .hero img {
      position: absolute;
      top: 120px; /* justér efter behov */
      right: 200px; /* skubber den ind fra højre */
      width: 300px; /* lidt større som i design */
    }

    .herotekst {
      position: absolute;
      top: 50%;
      left: 200px; /* i stedet for 50% */
      transform: translateY(-50%);
      max-width: 650px;
    }
    h1 {
      font-size: 3rem;
    }

    h2 {
      font-size: 2rem;
    }
  }
</style>
