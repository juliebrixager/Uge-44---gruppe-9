---
const { eventData } = Astro.props;
import KvadratKnap from "../components/KvadratKnap.astro";
---

<div class="eventcard-container">
  <div class="img-container">
    <img src={eventData.img} alt="" />
    <div>
      <p>{eventData.dato}</p>
    </div>
  </div>
  <div>
    <div class="text-container">
      <p class="text-bold">{eventData.event}</p>
      <p>{eventData.beskrivelse}</p>
    </div>
    <div class="cta-container">
      <KvadratKnap href="#" tekst="Læs mere" />
      <KvadratKnap href="#" tekst="Tilmelding" variant="blaa" />
    </div>
  </div>
</div>

<style>
  .eventcard-container {
    margin: 2rem 4rem;
    background-color: #bcceff;
    grid-area: 1/1;
  }

  /* img container */
  .img-container {
    display: grid;
  }

  .img-container img {
    grid-area: 1/1;
    object-fit: cover;
    width: 100%;
    height: 100%;
  }

  .img-container div {
    grid-area: 1/1;
    background-color: #fff;
    width: 120px;
    height: 80px;
    left: 30px;
    position: relative;
  }

  .img-container p {
    place-self: center;
    font-weight: 400;
    margin-top: 30px;
    font-size: 18px;
  }

  /* text container */
  .text-container {
    margin: 2rem 1rem;
    place-self: center;
  }
  .text-bold {
    font-weight: 600;
    margin-bottom: 2ch;
  }

  .cta-container {
    position: absolute;
    margin-left: 1rem;
  }

  /* desktop view */
  @media (width>=900px) {
    .eventcard-container {
      display: grid;
      grid-template-columns: 2fr 1fr;
    }

    .text-container {
      min-height: 115px;
    }
    .cta-container {
      position: relative;
      top: 25px;
    }
  }

  @media (width<900px) {
    .eventcard-container {
      padding-bottom: 2rem;
    }
  }
</style>
